# Road Sentry Environment Variables Example
# Duplicate this file as '.env.local' and fill in the values.

# 1. AI & Chatbot Configuration
# Obtain an API key from Google AI Studio (Gemini API)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Firebase Database Settings (Client-Side Config)
# These values are used to connect the Streetlight Alerts monitor to the RTDB & Cloud Firestore.
# Standard defaults are configured in 'src/lib/firebase.ts' but can be overridden here.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBcwWA49kHyMHKhO6ltEf8-6qq1yWuANJs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=streetlight-monitor-d8f2b.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://streetlight-monitor-d8f2b-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=streetlight-monitor-d8f2b
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=streetlight-monitor-d8f2b.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=425228443240
NEXT_PUBLIC_FIREBASE_APP_ID=1:425228443240:web:417fc57c4fa05d544965dd

# 3. Supabase Integration (Authentication & Database)
# These are used for database synchronization and secure user sessions.
NEXT_PUBLIC_SUPABASE_URL=https://your_supabase_project_id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
